# AnywhereInput Reference Configuration — NOT LOADED AT RUNTIME
#
# This file is FOR REFERENCE ONLY — it shows all available configuration options.
# These settings are NOT loaded by the server at startup.
#
# To configure the server, use ONE of these methods:
#   1. CLI flags:  anywhereinput --fps 120 --quality 40 --scale 0.7 --port 8008
#   2. Admin GUI:  anywhereinput --app  → Settings tab
#
# The server reads configuration ONLY from CLI arguments.
# Creating config/local_settings.yaml will NOT be read (not implemented).
# AnywhereInput Default Configuration
# Override by creating config/local_settings.yaml (gitignored)

server:
  host: "0.0.0.0"
  port: 8008
  debug: false

screen_capture:
  enabled: true
  fps: 10
  quality: 60
  scale: 0.5
  show_cursor: true

auth:
  token_length: 32
  token_rotation_hotkey: "ctrl+n"
  auto_generate: true

mouse:
  sensitivity: 1.0
  acceleration: false

tunnels:
  cloudflare:
    auto_download: true
    binary_name: "cloudflared"
  pinggy:
    ssh_host: "free.pinggy.io"
    ssh_port: 443
  zrok2:
    auto_enable: true
logging:
  level: "INFO"
  format: "%(asctime)s [%(levelname)s] %(message)s"
