# AnywhereInput Reference Configuration
#
# This file shows all available configuration options.
# It IS loaded at startup as project defaults.
# CLI flags (--fps, --quality, etc.) override these values.
# For user-specific overrides, create config/local_settings.yaml (gitignored).
#
# To configure the server, use ONE of these methods:
#   1. Edit this file directly (or copy to local_settings.yaml)
#   2. CLI flags:  anywhereinput --fps 120 --quality 40 --scale 0.7 --port 8008
#   3. Admin GUI:  anywhereinput --app  → Settings tab

server:
  host: "0.0.0.0"
  port: 8008
  debug: false

screen_capture:
  enabled: true
  fps: 120
  quality: 40
  scale: 0.7
  show_cursor: true

auth:
  token_length: 32
  token_rotation_hotkey: "ctrl+n"
  auto_generate: true

mouse:
  sensitivity: 1.5
  acceleration: false

tunnels:
  cloudflare:
    auto_download: true
    binary_name: "cloudflared"
  pinggy:
    ssh_host: "free.pinggy.io"
    ssh_port: 443
  zrok2:
    auto_enable: true

logging:
  level: "INFO"
  format: "%(asctime)s [%(levelname)s] %(message)s"
