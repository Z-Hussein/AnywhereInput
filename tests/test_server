"""Tests for WebSocket server."""
import pytest
from anywhereinput.server import AnywhereInputServer
from anywhereinput.screen_capture import ScreenCapture


def _has_display():
    """Check if a real X11/Wayland display is available for MSS."""
    try:
        sc = ScreenCapture()
        frame = sc.capture()
        sc.close()
        return frame is not None
    except Exception:
        return False


@pytest.fixture
def server():
    return AnywhereInputServer(port=18008)


def test_server_creation(server):
    assert server.host == "127.0.0.1"
    assert server.port == 18008
    # In headless environments screen capture is disabled by design.
    # Only assert enabled=True when a real display exists.
    if _has_display():
        assert server.screen.enabled is True
